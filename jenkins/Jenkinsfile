pipeline {
  agent any

  stages {

    stage('Checkout Code') {
      steps {
        echo "Fetching code from GitHub..."
        checkout scm
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        sh '''
        echo "Applying Kubernetes manifests..."

        kubectl apply -f k8s/deployment.yaml
        kubectl apply -f k8s/service.yaml
        '''
      }
    }

  }
}

