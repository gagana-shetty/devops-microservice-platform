pipeline {

  agent {
    kubernetes {
      yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: node
    image: node:18
    command:
      - cat
    tty: true

  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
      - /busybox/sh
    args:
      - -c
      - while true; do sleep 30; done
    env:
      - name: DOCKER_CONFIG
        value: /kaniko/.docker
    volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker

  - name: trivy
    image: aquasec/trivy:latest
    command:
      - cat
    tty: true

  volumes:
    - name: docker-config
      secret:
        secretName: dockerhub-secret
"""
    }
  }

  environment {
    IMAGE_NAME = "gagana1994/devops-microservice-app"
    IMAGE_TAG = "${BUILD_NUMBER}"
  }

  stages {

    stage('Checkout Code') {
      steps {
        git branch: 'main', url: 'https://github.com/gagana-shetty/devops-microservice-platform.git'
      }
    }

    stage('Install Dependencies') {
      steps {
        container('node') {
          sh '''
          cd app/backend
          npm install
          '''
        }
      }
    }

    stage('Run Tests') {
      steps {
        container('node') {
          sh '''
          cd app/backend
          npm test || true
          '''
        }
      }
    }

    stage('Filesystem Security Scan') {
      steps {
        container('trivy') {
          sh '''
          trivy fs .
          '''
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        container('kaniko') {
          sh '''
          /kaniko/executor \
            --dockerfile=app/backend/Dockerfile \
            --context=app/backend \
            --destination=$IMAGE_NAME:$IMAGE_TAG \
            --destination=$IMAGE_NAME:latest \
            --skip-tls-verify
          '''
        }
      }
    }

    stage('Container Image Scan') {
      steps {
        container('trivy') {
          sh '''
          trivy image $IMAGE_NAME:$IMAGE_TAG || true
          '''
        }
      }
    }

    stage('Update Kubernetes Deployment') {
      steps {
        sh '''
        sed -i "s|image: .*|image: $IMAGE_NAME:$IMAGE_TAG|" kubernetes/deployment.yaml
        '''
      }
    }

    stage('Push Manifest Changes') {
      steps {
        sh '''
        git config user.email "jenkins@local"
        git config user.name "jenkins"

        git add kubernetes/deployment.yaml
        git commit -m "update image to $IMAGE_TAG" || true
        git push origin main
        '''
      }
    }

  }

}
