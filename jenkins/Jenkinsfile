pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                echo "Cloning repository..."
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-app:latest app/backend'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f k8s/deployment.yaml'
                sh 'kubectl apply -f k8s/service.yaml'
            }
        }

    }
}
