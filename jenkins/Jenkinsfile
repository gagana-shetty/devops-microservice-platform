pipeline {
    agent any

    stages {

        stage('Build Image with Kaniko') {
            steps {
                container('kaniko') {
                    sh '''
                    /kaniko/executor \
                      --context=app/backend \
                      --dockerfile=app/backend/Dockerfile \
                      --destination=devops-app:latest \
                      --no-push
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f kubernetes/'
            }
        }

    }
}
