pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kubectl
    image: lachlanevenson/k8s-kubectl:v1.29.0
    command:
    - cat
    tty: true
'''
    }
  }

  stages {

    stage('Checkout Code') {
      steps {
        echo "Fetching code from GitHub..."
        checkout scm
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        container('kubectl') {
          sh '''
          echo "Applying Kubernetes manifests..."
          kubectl apply -f k8s/deployment.yaml
          kubectl apply -f k8s/service.yaml
          '''
        }
      }
    }

  }
}
